<idea-plugin>
    <id>com.jiangyuan.yuan-claw</id>
    <name>yuan-claw</name>
    <vendor url="https://github.com/ayuan">ayuan</vendor>

    <description><![CDATA[
        <h2>Yuan-Claw Runner</h2>
        <p>Quickly run the <code>yuan-claw</code> CLI tool from a toolbar button in IntelliJ IDEA, WebStorm, and other JetBrains IDEs.</p>
        <p>Features:</p>
        <ul>
          <li>One-click execution of <code>yuan-claw</code> in the IDE terminal</li>
          <li>Runs in the project root directory</li>
          <li>Reuses the same terminal tab across invocations</li>
        </ul>
    ]]></description>

    <change-notes><![CDATA[
        <ul>
          <li>1.0.0: Initial release</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <actions>
        <action
                id="com.jiangyuan.yuanclaw.RunYuanClaw"
                class="com.jiangyuan.yuanclaw.YuanClawAction"
                text="Run Yuan-Claw"
                description="Execute the yuan-claw command in the terminal"
                icon="/icons/yuan-claw.svg">
            <add-to-group group-id="ToolbarRunGroup" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="first"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt Y"/>
        </action>
    </actions>
</idea-plugin>
